---
const currentYear = new Date().getFullYear();

const footerLinks = {
  Projects: [
    { label: 'Venus (fj-doc)',     href: 'https://github.com/fugerit-org/fj-doc' },
    { label: 'Jupiter (fj-lib)',   href: 'https://github.com/fugerit-org/fj-lib' },
    { label: 'Mars (fj-daogen)',   href: 'https://github.com/fugerit-org/fj-daogen' },
    { label: 'Universe',           href: 'https://github.com/fugerit-org/fj-universe' },
  ],
  Tools: [
    { label: 'OpenAPI Doc Tool',   href: 'https://github.com/fugerit-org/openapi-doc-tool' },
    { label: 'Query Export Tool',  href: 'https://github.com/fugerit-org/query-export-tool' },
    { label: 'GraalVM Native',     href: 'https://github.com/fugerit-org/native-helper-graalvm' },
    { label: 'Issue Export',       href: 'https://github.com/fugerit-org/github-issue-export' },
  ],
  Resources: [
    { label: 'Maven Central',      href: 'https://repo1.maven.org/maven2/org/fugerit/java/' },
    { label: 'SonarCloud',         href: 'https://sonarcloud.io/organizations/fugerit-org/projects' },
    { label: 'GitHub Org',         href: 'https://github.com/fugerit-org' },
    { label: 'Contact',            href: 'mailto:d@fugerit.org' },
  ],
};
---

<footer class="footer">
  <div class="container">
    <div class="footer__grid">
      <div class="footer__brand">
        <a href="/" class="navbar__brand" style="display:flex;align-items:center;gap:0.75rem;text-decoration:none;">
          <img src="/fugerit-logo.svg" alt="Fugerit logo" width="36" height="36" />
          <span style="font-size:1rem;font-weight:700;color:var(--clr-white);">
            fugerit<span style="color:var(--clr-accent);">.org</span>
          </span>
        </a>
        <p>Open source Java libraries and tools to make development simpler, faster, and more reliable.</p>
        <div style="margin-top:1.25rem;display:flex;gap:0.75rem;">
          <a href="https://github.com/fugerit-org" target="_blank" rel="noopener noreferrer" class="btn btn-ghost" style="padding:0.4rem 0.8rem;font-size:0.82rem;" aria-label="GitHub">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
            GitHub
          </a>
          <a href="mailto:d@fugerit.org" class="btn btn-ghost" style="padding:0.4rem 0.8rem;font-size:0.82rem;" aria-label="Email">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            Email
          </a>
        </div>
      </div>

      {Object.entries(footerLinks).map(([section, links]) => (
        <div class="footer__col">
          <h4>{section}</h4>
          <ul>
            {links.map(link => (
              <li>
                <a href={link.href} target={link.href.startsWith('http') ? '_blank' : '_self'} rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}>
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="footer__bottom">
      <span>© {currentYear} Fugerit Coding Org. Apache-2.0 License.</span>
      <span>Made with ♥ in Italy &nbsp;🇮🇹</span>
    </div>
  </div>
</footer>
